// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  employee
  admin

  @@map("role")
}

enum OrgType {
  school
  supplier

  @@map("org_type")
}

enum OrderStatus {
  new
  published
  accepted
  in_progress
  completed
  cancelled

  @@map("order_status")
}

enum PaymentStatus {
  unpaid
  paid
  verified

  @@map("payment_status")
}

model Organization {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  name           String   @unique @map("name") @db.VarChar(255)
  type           OrgType  @map("type")
  contactEmail   String?  @unique @map("contact_email") @db.VarChar(255)
  contactPhone   String?  @unique @map("contact_phone") @db.VarChar(50)
  users          User[]   @relation("OrganizationUsers")
  schoolOrders   Order[]  @relation("SchoolOrders")
  supplierOrders Order[]  @relation("SupplierOrders")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("organizations")
}

model User {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  organizationId       String?              @map("organization_id") @db.Uuid
  organization         Organization?        @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: SetNull)
  email                String               @unique @map("email") @db.VarChar(255)
  passwordHash         String               @map("password_hash") @db.VarChar(255)
  firstName            String?              @map("first_name") @db.VarChar(255)
  lastName             String?              @map("last_name") @db.VarChar(255)
  avatarUrl            String?              @map("avatar_url") @db.Text
  role                 Role                 @map("role")
  orderStatusHistories OrderStatusHistory[] @relation("OrderStatusHistoryActors")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("users")
}

model Category {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  name        String     @unique @map("name") @db.VarChar(255)
  description String?    @map("description") @db.Text
  menuItems   MenuItem[] @relation("CategoryMenuItems")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("categories")
}

model MenuItem {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String?     @map("category_id") @db.Uuid
  category    Category?   @relation("CategoryMenuItems", fields: [categoryId], references: [id], onDelete: SetNull)
  name        String      @unique @map("name") @db.VarChar(255)
  description String?     @map("description") @db.Text
  price       Decimal     @map("price") @db.Decimal(10, 2)
  isAvailable Boolean     @default(true) @map("is_available")
  images      MenuImage[] @relation("MenuItemImages")
  orderItems  OrderItem[] @relation("OrderItemMenuItems")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([categoryId])
  @@map("menu_items")
}

model MenuImage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuItemId String   @map("menu_item_id") @db.Uuid
  menuItem   MenuItem @relation("MenuItemImages", fields: [menuItemId], references: [id], onDelete: Cascade)
  imageUrl   String   @unique @map("image_url") @db.Text
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([menuItemId, isPrimary], map: "unique_primary_image_per_item")
  @@map("menu_images")
}

model Order {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId             String?              @map("school_id") @db.Uuid
  school               Organization?        @relation("SchoolOrders", fields: [schoolId], references: [id], onDelete: SetNull)
  supplierId           String?              @map("supplier_id") @db.Uuid
  supplier             Organization?        @relation("SupplierOrders", fields: [supplierId], references: [id], onDelete: SetNull)
  deliveryDate         DateTime?            @map("delivery_date") @db.Date
  orderStatus          OrderStatus          @default(new) @map("status")
  paymentStatus        PaymentStatus        @default(unpaid) @map("payment_status")
  totalPrice           Decimal              @default(0) @map("total_price") @db.Decimal(10, 2)
  comment              String?              @map("comment") @db.Text
  orderItems           OrderItem[]          @relation("OrderOrderItems")
  orderStatusHistories OrderStatusHistory[] @relation("OrderStatusHistoryOrders")
  createdAt            DateTime             @default(now()) @map("created_at")
  publishedAt          DateTime?            @map("published_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([schoolId])
  @@index([supplierId])
  @@map("orders")
}

model OrderItem {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orderId    String    @map("order_id") @db.Uuid
  order      Order     @relation("OrderOrderItems", fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?   @map("menu_item_id") @db.Uuid
  menuItem   MenuItem? @relation("OrderItemMenuItems", fields: [menuItemId], references: [id], onDelete: SetNull)
  quantity   Int       @default(1) @map("quantity")
  price      Decimal   @map("price") @db.Decimal(10, 2)
  addedAt    DateTime  @default(now()) @map("added_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model OrderStatusHistory {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orderId        String      @map("order_id") @db.Uuid
  order          Order       @relation("OrderStatusHistoryOrders", fields: [orderId], references: [id], onDelete: Cascade)
  previousStatus OrderStatus @map("previous_status")
  newStatus      OrderStatus @map("new_status")
  actorId        String?     @map("actor_id") @db.Uuid
  actor          User?       @relation("OrderStatusHistoryActors", fields: [actorId], references: [id], onDelete: SetNull)
  changedAt      DateTime    @default(now()) @map("changed_at")

  @@index([orderId])
  @@index([actorId])
  @@map("order_status_history")
}
